PORT=3000

# Optional. If blank or unset, requests are accepted without an API key.
# If set, Bubble must send this value as the x-golf-trackr-api-key header.
GOLF_TRACKR_API_KEY=

# Optional tuning.
OVERPASS_URL=https://overpass-api.de/api/interpreter
COURSE_CACHE_TTL_MS=2592000000
SEARCH_RADIUS_METERS=5000
FEATURE_RADIUS_METERS=5000
HOLE_MATCH_METERS=100
MAX_HAZARDS=3
